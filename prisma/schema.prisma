generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum ServiceCategory {
  MODULO_BATERIA_PIN_O_MAYOR_20K // $1.500
  REVISION_APROBADA              // $2.000
  LIMPIEZA_O_MENOR_20K           // $650
  DENEGADA_SIN_REPARACION        // $0
}

enum Capacity {
  GB_128
  GB_256
  GB_512
  TB_1
  TB_2
}

enum TargetAchievement {
  LESS_THAN_100     // < 100% (1%)
  EXACTLY_100       // 100% (1.4%)
  EXACTLY_110       // 110% (1.6%)
  GREATER_EQUAL_125 // >= 125% (1.8%)
}

// ==========================================
// 1. SERVICIO TÉCNICO
// ==========================================

model TechnicalService {
  id      String   @id @default(uuid())
  coders  String   @unique
  date    DateTime
  model   String
  branch  String

  userId   String?
  user     User?    @relation(fields: [userId], references: [id])

  services ServiceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceItem {
  id                 String           @id @default(uuid())
  technicalServiceId String
  technicalService   TechnicalService @relation(fields: [technicalServiceId], references: [id], onDelete: Cascade)

  serviceType        ServiceCategory
  sku                String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ==========================================
// 2. COMPRAS DE CELULARES
// ==========================================

model DevicePurchase {
  id            String   @id @default(uuid())
  purchaseOrder String   @unique
  date          DateTime
  model         String
  capacity      Capacity

  userId        String?
  user          User?    @relation(fields: [userId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ==========================================
// 3. VENTAS DE CELULARES (Registro Mensual)
// ==========================================

model DeviceSalesMonthly {
  id            String   @id @default(uuid())
  month         Int
  year          Int
  totalQuantity Int
  totalVolume   Float

  userId        String?
  user          User?    @relation(fields: [userId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([month, year])
}

// ==========================================
// 4. VENTAS GENERALES (Registro Mensual)
// ==========================================

model GeneralSalesMonthly {
  id               String            @id @default(uuid())
  month            Int
  year             Int
  grossSalesVolume Float
  target           TargetAchievement

  userId           String?
  user             User?    @relation(fields: [userId], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([month, year])
}

// ==========================================
// 5. USUARIOS (Autenticación y Roles)
// ==========================================

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  adminPassword String
  viewerPin     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  technicalServices   TechnicalService[]
  devicePurchases     DevicePurchase[]
  deviceSalesMonthly  DeviceSalesMonthly[]
  generalSalesMonthly GeneralSalesMonthly[]
}
